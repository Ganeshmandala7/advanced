# FeXsics Environment Configuration

# Python
PYTHONUNBUFFERED=1

# FeXsics Configuration
FEXSICS_DEBUG=False
FEXSICS_LOG_LEVEL=INFO
FEXSICS_DATA_DIR=./data
FEXSICS_RESULTS_DIR=./results

# Deep Learning
TORCH_DEVICE=cuda
TF_CPP_MIN_LOG_LEVEL=2

# API Configuration (if enabled)
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False

# GPU Configuration
CUDA_VISIBLE_DEVICES=0
CUDA_LAUNCH_BLOCKING=1
